# Binance Futures connector — copy to .env and fill in your keys.
# .env is excluded from git. Never commit real credentials.
#
# Testnet keys: https://testnet.binancefuture.com/

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Set to "false" or "0" to switch to mainnet (requires real funds — use with care)
BINANCE_TESTNET=true

# Trading pair
BINANCE_SYMBOL=BTCUSDT
